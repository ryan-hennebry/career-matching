.env
# Live run state — seeded empty/scrubbed once, then ignored (jsa rewrites it each run)
state.json
output/jobs/*.json
__pycache__/
output/briefs/*.pdf
output/digests/*.pdf
.claude/settings.local.json
.playwright-mcp/
*.png
*.txt
!requirements.txt
.vercel
# --- private job-search artifacts (never publish) ---
output/_final_board_*
# ...except the synthetic sample board, which is safe to publish (fake data)
!output/_final_board_sample.json
output/session-state.md
output/*_exclusion.json
output/RESUME-HANDOFF.md
output/_cv_parsed*.json
output/deep/
output/rerank/
output/strict/
output/verified/
output/verified-prior/
output/.channels/
output/*.xlsx
# keep placeholder structure only
!output/**/.gitkeep
# durable private state (sidecar, see 4d)
.private/
